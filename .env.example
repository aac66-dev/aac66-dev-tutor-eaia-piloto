# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_PROJECT_REF=your-project-ref

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# GitHub
GITHUB_REPO_URL=https://github.com/your-user/antigravity-aep

# Piloto
AEP_ENV=development
AEP_DEFAULT_MODEL=claude-sonnet-4-5-20250929
AEP_OPUS_MODEL=claude-opus-4-5-20250929
AEP_MAX_TOKENS=4096
AEP_MONTHLY_BUDGET_USD=50
